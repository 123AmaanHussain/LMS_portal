# ============================================================
# Library Management System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase credentials
# NEVER commit your actual .env file to version control!
# ============================================================

# Get these from: Supabase Dashboard → Settings → Database → Connection Pooling
# Use the "Transaction" pooler (port 6543), NOT the direct connection (port 5432)

DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/<your-db-name>?prepareThreshold=0&sslmode=require
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=<your-supabase-db-password>
PORT=9090


# ─── How to find these values ───────────────────────────────
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Click Settings (gear icon) → Database
# 4. Scroll to "Connection Pooling"
# 5. Select Mode: Transaction
# 6. Copy the connection string and extract Host, User, Password
#
# Example:
# DB_URL=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepareThreshold=0&sslmode=require
# DB_USER=postgres.abcdefghijklmnop
# DB_PASSWORD=MySecurePassword123
